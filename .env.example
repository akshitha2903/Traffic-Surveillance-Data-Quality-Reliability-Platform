# ============================================
# Traffic Quality Platform — Environment Config
# Copy this file to .env and fill in real values
# Never commit .env to git
# ============================================

# --- Postgres / TimescaleDB ---
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=traffic_quality
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Qdrant (vector DB) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- FastAPI backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM Providers (Phase 4) ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=

# --- Observability (Phase 4) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=traffic-quality-platform
LANGSMITH_TRACING=true

# --- Camera simulator ---
SIMULATED_CAMERA_COUNT=5
HEARTBEAT_INTERVAL_SECONDS=30
